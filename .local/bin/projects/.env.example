#!/bin/bash

export SESH="Police-Supplies-M2"                  # name of the project dir e.g. /home/matt/projects/<this dir>
export PROJECT_DIR="/home/matt/projects/$SESH"
export STYLES_DIR=""                              # name of the styles dir e.g. $PROJECT_DIR/magento/app/design/frontend/<vendor name>/<theme_name>/web/tailwind
export COMPOSE_DIR=$PROJECT_DIR
export ALIAS=""                                   # e.g. ki
export LOG="/tmp/tmux-$SESH.log"
export SSH_STAGING=""                             # user@host e.g. app@hypernode.io
export SSH_PROD="app@policesupplies.hypernode.io" # same as above
export STYLES_CMD="npm run watch"
export DOCKER_MAIN_CONTAINER_NAME=""              # name of the main docker container which you want to exec into to run cmds
